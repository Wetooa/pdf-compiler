# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
# Copy this file to .env and add your API key
GEMINI_API_KEY=your_gemini_api_key_here

# Authentication (single shared password for the web app)
# If unset, login returns 503 and the app cannot be used.
APP_PASSWORD=your_app_password_here
# Optional: JWT signing secret (defaults to APP_PASSWORD if not set)
# JWT_SECRET=your_jwt_secret_here

# Database (used by API for batches and blob storage)
# Default below matches docker-compose postgres service
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pdf_compiler

# Optional: Gemini Model name (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Optional: OCR Configuration
# OCR_DPI=300
# OCR_LANG=eng

# Optional: Processing Configuration
# PAGES_PER_GROUP=5
# DEFAULT_OVERLAP=2

# Optional: Output Configuration (temporary processing output)
# DEFAULT_OUTPUT_DIR=./output

# Optional: SQL echo (set to 1 for SQL logging)
# SQL_ECHO=0

